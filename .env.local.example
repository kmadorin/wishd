# Pick ONE auth method:

# Option A — Claude Code OAuth (uses your Pro/Max subscription, no API credits)
# Get with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Option B — Anthropic API key (pay-per-token via console.anthropic.com)
ANTHROPIC_API_KEY=

# Uniswap Trading API key (required for Mainnet/Base/Arb/Op/Polygon/Unichain swaps)
UNISWAP_API_KEY=

# Optional per-chain RPC overrides (defaults to viem chain.rpcUrls.default)
RPC_URL_1=
RPC_URL_8453=
RPC_URL_42161=
RPC_URL_10=
RPC_URL_137=
RPC_URL_130=
RPC_URL_11155111=
